# CEC-WAM-HOT-CORE — Environment Variable Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file. It is listed in .gitignore.
# Rotate any key that has already been exposed in the git history.

# ── Google Sheets ────────────────────────────────────────────────────────────
# Published CSV URL for the primary live-data sheet.
# In Google Sheets: File → Share → Publish to web → CSV → copy the link.
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/e/<PUBLISHED_ID>/pub?output=csv

# Sheet ID for the secure/frozen sheet (private – never publish this URL).
# Find it in the sheet URL: docs.google.com/spreadsheets/d/<SHEET_ID>/edit
FROZEN_SHEET_ID=

# ── NASA API ─────────────────────────────────────────────────────────────────
# Free key from https://api.nasa.gov/ (higher rate limits than DEMO_KEY).
NASA_API_KEY=DEMO_KEY

# ── OpenWeatherMap ───────────────────────────────────────────────────────────
# Free key from https://openweathermap.org/api
OPENWEATHER_API_KEY=

# ── OpenAI ───────────────────────────────────────────────────────────────────
# API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4

# ── ElevenLabs (EVE voice synthesis) ────────────────────────────────────────
# API key from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Voice ID to use for synthesis (default is Adam)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Groq (EVE Sovereign / Eve_sovereign_v6_updated.py) ──────────────────────
# API key from https://console.groq.com/keys
GROQ_API_KEY=
# Model to use for Groq inference (default: llama-3.1-70b-versatile)
GROQ_MODEL=llama-3.1-70b-versatile

# ── EVE Agent Personality ────────────────────────────────────────────────────
EVE_SYSTEM_CODE=CEC_WAM_HEI_EVE_7A2F-9C4B
EVE_OWNER_NAME=Twan
EVE_PERSONALITY=professional,helpful,intelligent,learning,warm,light-island-rhythm
